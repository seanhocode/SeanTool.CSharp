<Window x:Class="SeanTool.CSharp.Net8.WPF.Test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SeanTool.CSharp.Net8.WPF.Test"
        xmlns:WPFTool="clr-namespace:SeanTool.CSharp.Net8.WPF;assembly=WPFTool"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WPFTool:ModelEditorView Grid.Row="0" TargetObject="{Binding TestPerson}" />

        <Button Grid.Row="1" Click="GetModelValue" Height="30" Margin="5">GetValue</Button>
        <Button Grid.Row="2" Click="OpenModelEditorWindow" Height="30" Margin="5">OpenModelEditorWindow</Button>
    </Grid>
</Window>
