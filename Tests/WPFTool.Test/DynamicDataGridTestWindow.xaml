<Window x:Class="SeanTool.CSharp.WPF.Test.DynamicDataGridTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SeanTool.CSharp.WPF.Test"
        xmlns:WPFTool="clr-namespace:SeanTool.CSharp.WPF;assembly=WPFTool"
        mc:Ignorable="d"
        Title="DynamicDataGridTestWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="300"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WPFTool:DynamicDataGrid Grid.Row="0"
                DataSource="{Binding PersonList}"
                ColumnDefinitions="{Binding ColumnDefinitions}"
                IsReadOnly="False"/>
        <Button Grid.Row="1" Click="CheckDataValue" Height="30" Margin="5">CheckValue</Button>
    </Grid>
</Window>
